{
  "compileOnSave": false,
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "dom"],
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "baseUrl": ".",
    "rootDir": ".",
    "module": "ESNext",
    "moduleResolution": "node",
    "paths": {
      "@ethernauta/abi": ["packages/abi/src/index.ts"],
      "@ethernauta/chain": ["packages/chain/src/index.ts"],
      "@ethernauta/connector": ["packages/connector/src/index.ts"],
      "@ethernauta/eth": ["packages/eth/src/index.ts"],
      "@ethernauta/sol": ["packages/sol/src/index.ts"],
      "@ethernauta/transport": ["packages/transport/src/index.ts"]
    },
    "declaration": false,
    "importHelpers": true,
    "sourceMap": true,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true
  },
  "exclude": ["node_modules", "tmp"]
}
