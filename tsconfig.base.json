{
  "compileOnSave": false,
  "compilerOptions": {
    "target": "es2015",
    "lib": ["es2020", "dom"],
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "baseUrl": ".",
    "rootDir": ".",
    "module": "esnext",
    "moduleResolution": "node",
    "paths": {
      "@ethernauta/abi": ["packages/abi/src/index.ts"],
      "@ethernauta/core": ["packages/core/src/index.ts"],
      "@ethernauta/chain": ["packages/chain/src/index.ts"],
      "@ethernauta/legacy": ["packages/legacy/src/index.ts"],
      "@ethernauta/method": ["packages/method/src/index.ts"],
      "@ethernauta/transport": ["packages/transport/src/index.ts"]
    },
    "declaration": false,
    "importHelpers": true,
    "sourceMap": true,
    "skipDefaultLibCheck": true,
    "skipLibCheck": true
  },
  "exclude": ["node_modules", "tmp"]
}
