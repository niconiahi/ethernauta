{
  "$schema": "https://json.schemastore.org/chrome-manifest",
  "manifest_version": 3,
  "name": "@ethernauta/wallet",
  "version": "0.0.1",
  "description": "A wallet browser extension that only signs",
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "extension.entry.mjs"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://ethernauta.niconiahi.workers.dev/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://ethernauta.niconiahi.workers.dev/*"
      ],
      "js": ["browser.entry.mjs"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://ethernauta.niconiahi.workers.dev/*"
      ],
      "resources": ["wallet.mjs"]
    }
  ]
}
