{
  "$schema": "https://json.schemastore.org/chrome-manifest",
  "manifest_version": 3,
  "name": "Ethernauta",
  "version": "0.0.2",
  "description": "Self-custody Ethereum wallet. Create a wallet, store your keys encrypted locally, and sign transactions — nothing ever leaves your device.",
  "homepage_url": "https://ethernauta.niconiahi.workers.dev/privacy-policy",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "extension.entry.mjs"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://ethernauta.niconiahi.workers.dev/*",
    "https://ethereum-sepolia-rpc.publicnode.com/*",
    "http://localhost/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://ethernauta.niconiahi.workers.dev/*",
        "http://localhost/*"
      ],
      "js": ["browser.entry.mjs"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://ethernauta.niconiahi.workers.dev/*",
        "http://localhost/*"
      ],
      "resources": ["wallet.mjs"]
    }
  ]
}
